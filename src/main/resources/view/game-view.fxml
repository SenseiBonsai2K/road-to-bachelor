<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Label?>
<BorderPane xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.unicam.cs.mpgc.rpg119001.presentation.controller.GameController"
            prefHeight="600.0" prefWidth="800.0">

    <center>

        <StackPane>

            <HBox alignment="CENTER"
                  StackPane.alignment="CENTER">

                <VBox prefWidth="150" minWidth="150">
                    <Label fx:id="playerNameLabel"/>
                    <ListView fx:id="playerStatsList"/>
                </VBox>

                <StackPane fx:id="gameStack"
                           prefWidth="656"
                           prefHeight="464"
                           minWidth="656"
                           maxWidth="656">

                    <AnchorPane fx:id="gamePane"
                                prefWidth="656"
                                prefHeight="464"/>
                </StackPane>

                <VBox prefWidth="150" minWidth="150">
                    <Label fx:id="selectedEnemyNameLabel"/>
                    <ListView fx:id="selectedEnemyStatsList"/>
                </VBox>

            </HBox>

        </StackPane>

    </center>

    <bottom>
        <HBox alignment="CENTER"
              spacing="20"
              prefHeight="60.0"
              BorderPane.alignment="CENTER">

            <Button fx:id="saveGameButton"
                    text="Save"
                    prefWidth="120"
                    onAction="#saveGame"/>

            <Button fx:id="saveAndExit"
                    text="Save and Exit"
                    prefWidth="120"
                    onAction="#saveAndExit"/>

        </HBox>
    </bottom>

</BorderPane>